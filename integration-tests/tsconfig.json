{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "composite": true,
        "declaration": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "creditcoin-js/*": ["../creditcoin-js/lib/*"]
        }
    },
    "references": [{ "path": "../creditcoin-js/" }],
    "include": ["./**/*.ts", "./**/*.json"],
    "jest": {
        "require": ["tsconfig-paths/register"],
        "compilerOptions": {
            "rootDir": "../"
        }
    }
}
